{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Homework Scoring Output",
  "description": "Schema for a single homework scoring result produced by the evaluation engine.",
  "type": "object",
  "required": [
    "student_id",
    "rubric_id",
    "scored_at",
    "gate_status",
    "dimension_scores",
    "weighted_total",
    "grade",
    "overall_confidence",
    "comment"
  ],
  "properties": {
    "student_id": {
      "type": "string",
      "description": "Anonymous student identifier (e.g., anon-001)"
    },
    "rubric_id": {
      "type": "string",
      "description": "ID of the Rubric used for scoring"
    },
    "scored_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when scoring completed"
    },
    "gate_status": {
      "type": "object",
      "required": ["all_passed", "details"],
      "properties": {
        "all_passed": {
          "type": "boolean",
          "description": "Whether all gates with on_fail=fail passed"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate_id", "passed", "message"],
            "properties": {
              "gate_id": { "type": "string" },
              "passed": { "type": "boolean" },
              "message": { "type": "string" },
              "on_fail": {
                "type": "string",
                "enum": ["fail", "flag", "warn"]
              }
            }
          }
        }
      }
    },
    "dimension_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "criterion_id",
          "criterion_name",
          "weight",
          "score",
          "evidence",
          "reasoning",
          "improvement",
          "confidence"
        ],
        "properties": {
          "criterion_id": {
            "type": "string",
            "description": "Matches the criterion key in the Rubric"
          },
          "criterion_name": {
            "type": "string",
            "description": "Human-readable dimension name"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Weight of this dimension (from Rubric)"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Score on 1-5 Likert scale"
          },
          "evidence": {
            "type": "string",
            "minLength": 1,
            "description": "Direct quote or observation from the submission supporting this score"
          },
          "reasoning": {
            "type": "string",
            "minLength": 1,
            "description": "Chain-of-thought reasoning comparing evidence against anchor descriptions"
          },
          "improvement": {
            "type": "string",
            "minLength": 1,
            "description": "One specific, actionable improvement suggestion for this dimension"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence score for this dimension (0-1)"
          }
        }
      }
    },
    "weighted_total": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Sum of (weight * score) across all dimensions"
    },
    "percentile_score": {
      "type": "integer",
      "minimum": 40,
      "maximum": 100,
      "description": "Mapped to 40-100 scale: round((weighted_total - 1) / 4 * 60 + 40)"
    },
    "grade": {
      "type": "string",
      "enum": ["accept", "review", "reject"],
      "description": "Grade classification based on thresholds"
    },
    "overall_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Aggregated confidence across all dimensions"
    },
    "review_flag": {
      "type": "string",
      "enum": ["none", "low_confidence", "gate_warning", "manual_review"],
      "description": "Reason for flagging this submission for human review"
    },
    "comment": {
      "type": "object",
      "required": ["strengths", "weaknesses", "suggestions"],
      "properties": {
        "strengths": {
          "type": "string",
          "minLength": 1,
          "description": "Specific strengths with evidence from the submission"
        },
        "weaknesses": {
          "type": "string",
          "minLength": 1,
          "description": "Specific weaknesses with evidence from the submission"
        },
        "suggestions": {
          "type": "string",
          "minLength": 1,
          "description": "Actionable improvement suggestions"
        },
        "full_text": {
          "type": "string",
          "description": "Combined comment text (200-400 characters for zh-CN)"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "model": { "type": "string" },
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "duration_ms": { "type": "integer" }
      }
    }
  }
}
